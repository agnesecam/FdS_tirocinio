                    <lb xml:id="lb18_p1" n="18" facs="#facs_p1_lb17"/>
                    ou à pronostiquer 
                    <lb xml:id="lb19_p1" n="19" facs="#..."/>
                    son avenir, 
                    <lb xml:id="lb20_p1" n="20" facs="#..."/>
                    à définir son 
                    <lb xml:id="lb21_p1" n="21" facs="#..."/>
                    but, son utilité,
                    <lb xml:id="lb22_p1" n="22" facs="#..."/>
                    à marquer la 
                    <lb xml:id="lb23_p1" n="23" facs="#..."/>
                    place qu’elle 
                    <lb xml:id="lb24_p1" n="24" facs="#..."/>
                    occupe dans le 
                    <lb xml:id="lb25_p1" n="25" facs="#..."/>
                    cercle des <choice><abbr>conn.</abbr> <expan>conn<ex>aissances</ex></expan></choice>
                    <lb xml:id="lb26_p1" n="26" facs="#..."/>
                    humaines et les 
                    <lb xml:id="lb27_p1" n="27" facs="#..."/>
                    services qu’elle peut 
                    <lb xml:id="lb28_p1" n="28" facs="#..."/>
                    rendre dans une</add> 
                    <lb xml:id="lb29_p1" n="29" facs="#..."/>
                    <orgName ref="#FacLettres">Faculté des lettres</orgName>, <del rend="overstrike"><gap reason="illegible" extent="3" unit="lines"/></del> <add place="above">je craindrais de ne pas remplir très</add> 
                    <lb xml:id="lb30_p1" n="30" facs="#..."/>
                    <add place="above">dignement ma tâche, mais <choice><abbr>certain.</abbr> <expan>certain<ex>ement</ex></expan></choice></add> 
                    <lb xml:id="lb31_p1" n="31" facs="#..."/>
                    <add place="above">je ne pourrais me plaindre ici de l’abandon.</add>

                <ab xml:id="91Aaaa002"/> <!--milestone perché la pericope continua nella seconda pagina-->
                    <lb xml:id="lb32_p1" n="32" facs="#..."/>
                    <add place="left margin">Sans exalter 
                    <lb xml:id="lb33_p1" n="33" facs="#..."/>
                    outre mesure 
                    <lb xml:id="lb34_p1" n="34" facs="#..."/>
                    les mérites de la <term subtype="linguistics-term" ref="#linguistique"> linguistique</term>,
                    <lb xml:id="lb35_p1" n="35" facs="#..."/>
                    quel est le </add> 
                    <lb xml:id="lb36_p1" n="36" facs="#..."/>
                    profit que peut tirer <del rend="overstrike">de cette</del> par <choice><abbr>ex.</abbr> <expan>ex<ex>emple</ex></expan></choice> de cette 
                    <lb xml:id="lb37_p1" n="37" facs="#..."/>
                    étude l’érudition classique, 
                    <lb xml:id="lb38_p1" n="38" facs="#..."/>
                    la connaissance des <term subtype="linguistics-term" ref="#langues">langues</term> grecque, latine et française; 
                    <lb xml:id="lb39_p1" n="39" facs="#..."/>
                    eût-elle un 
                    <lb xml:id="lb40_p1" n="40" facs="#..."/>
                    but simplement 
                    <lb xml:id="lb41_p1" n="41" facs="#..."/>
                    <term subtype="linguistics-term" ref="#litteraire">littéraire</term>, 
                    <lb xml:id="lb42_p1" n="42" facs="#..."/>
                    l’intérêt que peut avoir ensuite la même 
                    <lb xml:id="lb43_p1" n="43" facs="#..."/>
                    étude pour <del rend="overstrike">l'<gap reason="illegible" extent="3" unit="chars"/></del>l’<term subtype="?" ref="#histoire">histoire</term> ou pour 
                
