        <body xml:lang="fr">
            <pb n="1" ed="DigitalEdition" xml:id="body_p" facs="facs_p1" hand="h1"/> <!-- quale edizione ed=""? -->
            <ab xml:id="pageNumber1" rend="align(left)" facs="#..."> 1 </ab>
            <ab xlm:id="printedNumber2" rend="align(right)" facs="#..."> 2 </ab>
            <div xml:id="div_p1" hand="#h1">
                <p xml:id="91Aaaa001"/><!--milestone perché le pericopi possono essere divise da un pb--> <!--NOTA RIUNIONE: USA AB E SEG-->
                    <lb xml:id="lb1_p1" n="1" facs="#..."/>
                    Si la chaire que j’ai en ce 
                    <lb xml:id="lb2_p1" n="2" facs="#..."/>
                    moment l’honneur d’inaugurer représentait un ordre 
                    <lb xml:id="lb3_p1" n="3" facs="#..."/>
                    d’études nouveau 
                    <lb xml:id="lb5_p1" n="5" facs="#..."/>
                    dans <orgName ref="#UniGeneve">notre Université <supplied resp="#AC"> de Genève</supplied><!--da omettere i supplied?--></orgName>, si j’avais
                    <lb xml:id="lb6_p1" n="6" facs="#..."/>
                    aujourd’hui la mission ou le privilège 
                    <lb xml:id="lb5_p1" n="7" facs="#..."/>
                    de vous introduire dans l’édifice 
                    <lb xml:id="lb5_p1" n="8" facs="#..."/>
                    que la <term subtype="linguistics-term" ref="#science-du-langage"><choice><abbr>sc.</abbr> <expan>sc<ex>ience</ex></expan></choice> du 
                    <lb xml:id="lb5_p1" n="9" facs="#..."/>
                    langage</term> est <choice><abbr>occ.</abbr> <expan>occ<ex>upée</ex></expan></choice> à <choice><abbr>constr.</abbr> <expan>constr<ex>uire</ex></expan></choice> depuis 
                    <lb xml:id="lb5_p1" n="10" facs="#..."/>
                    <date notBefore="1821" notAfter="1891"> <num type="cardinal" value="70">soixante-dix</num> ans <precision match="@notBefore" precision="low"/> <precision match="@notAfter" precision="high"/> </date>,
                    <lb xml:id="lb5_p1" n="11" facs="#..."/>
                    à 
                    <lb xml:id="lb5_p1" n="12" facs="#..."/>
                    décrire 
                    <lb xml:id="lb5_p1" n="13" facs="#..."/>
                    dans ses grandes 
                    <lb xml:id="lb5_p1" n="14" facs="#..."/>
                    lignes l’état présent 
                    <lb xml:id="lb5_p1" n="15" facs="#..."/>
                    de cette science,
                    <lb xml:id="lb5_p1" n="16" facs="#..."/>
                    à parcourir 
                    <lb xml:id="lb5_p1" n="17" facs="#..."/>
                    son passé, qui 
                    <lb xml:id="lb5_p1" n="18" facs="#..."/>
                    n’est pas très long, 
                    <lb xml:id="lb5_p1" n="19" facs="#..."/>
                    ou à pronostiquer 
                    <lb xml:id="lb5_p1" n="20" facs="#..."/>
                    son avenir, à définir son 
                    <lb xml:id="lb5_p1" n="21" facs="#..."/>
                    but, son utilité,
                    <lb xml:id="lb5_p1" n="22" facs="#..."/>
                    à marquer la 
                    <lb xml:id="lb5_p1" n="23" facs="#..."/>
                    place qu’elle 
                    <lb xml:id="lb5_p1" n="24" facs="#..."/>
                    occupe dans le 
                    <lb xml:id="lb5_p1" n="25" facs="#..."/>
                    cercle des <choice><abbr>conn.</abbr> <expan>conn<ex>aissances</ex></expan></choice>
                    <lb xml:id="lb5_p1" n="26" facs="#..."/>
                    humaines et les 
                    <lb xml:id="lb5_p1" n="27" facs="#..."/>
                    services qu’elle peut 
                    <lb xml:id="lb5_p1" n="28" facs="#..."/>
                    rendre dans une 
                    <lb xml:id="lb5_p1" n="29" facs="#..."/>
                    <orgName ref="#FacLettres">Faculté des lettres</orgName>, je craindrais de ne pas remplir très 
                    <lb xml:id="lb5_p1" n="30" facs="#..."/>
                    dignement ma tâche, mais <choice><abbr.>certain.</abbr> <expan>certain<ex>ement</ex></expan> 
                    <lb xml:id="lb5_p1" n="31" facs="#..."/>
                    je ne pourrais me plaindre ici de l’abandon.

                <p xml:id="91Aaaa002"/> <!--milestone perché la pericope continua nella seconda pagina-->
                    <lb xml:id="lb5_p1" n="32" facs="#..."/>
                    Sans exalter 
                    <lb xml:id="lb5_p1" n="33" facs="#..."/>
                    outre mesure 
                    <lb xml:id="lb5_p1" n="34" facs="#..."/>
                    les mérites de la <term subtype="linguistics-term" ref="#linguistique"> linguistique</term>,
                    <lb xml:id="lb5_p1" n="35" facs="#..."/>
                    quel est le 
                    <lb xml:id="lb5_p1" n="36" facs="#..."/>
                    profit que peut tirer par <choice><abbr>ex.</abbr> <expan>ex<ex>emple</ex></expan></choice> de cette 
                    <lb xml:id="lb5_p1" n="37" facs="#..."/>
                    étude l’érudition classique, 
                    <lb xml:id="lb5_p1" n="38" facs="#..."/>
                    la connaissance des <term subtype="linguistics-term" ref="#langues">langues</term> grecque, latine et française; 
                    <lb xml:id="lb5_p1" n="39" facs="#..."/>
                    eût-elle un 
                    <lb xml:id="lb5_p1" n="40" facs="#..."/>
                    but simplement 
                    <lb xml:id="lb5_p1" n="41" facs="#..."/>
                    <term subtype="linguistics-term" ref="#litteraire">littéraire</term>, 
                    <lb xml:id="lb5_p1" n="42" facs="#..."/>
