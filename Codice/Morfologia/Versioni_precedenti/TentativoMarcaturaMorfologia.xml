        <body xml:lang="fr">
            <pb n="1" ed="DigitalEdition" xml:id="body_p1" facs="facs_p1"/> <!-- quale edizione ed=""? -->
            <ab xml:id="HandPageNumber-1" rend="align(right)" facs="#..."> 1 </ab>
