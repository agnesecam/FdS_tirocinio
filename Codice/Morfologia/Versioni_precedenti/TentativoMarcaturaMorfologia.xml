            <!-- ListTerm -->
            <list type="terminology">                  
                <!-- Morphologie -->
                <label>
                    <term subtype="linguistics-term" xml:lang="fr" xml:id="morphologie" key="">Morphologie</term>
                </label>
                <item>
                    <gloss xml:lang="it" target="#morphologie">
                        In linguistics, morphology (/mɔːrˈfɒlədʒi/) is the study of words, how they are formed, and their relationship to other words in the same language. It analyzes the structure of words and parts of words such as stems, root words, prefixes, and suffixes.
                    </gloss>
                    <note>...</note>
                </item>
                <!-- Langage -->
                <label>
                    <term subtype="linguistics-term" xml:lang="fr" xml:id="langage" key="">langage</term>
                </label>
                <item>
                    <gloss xml:lang="it" target="#langage">
                        Primarily refers to language as a general phenomenon, or to the human ability to have language
                    </gloss>
                    <note>...</note>
                </item>
                <!-- Phonétique -->
                <label>
                    <term subtype="linguistics-term" xml:lang="fr" xml:id="phonétique" key="">phonétique</term>
                </label>
                <item>
                    <gloss xml:lang="it" target="#phonétique">
                        Branch of linguistics that focuses on the production and classification of the world's speech sounds. The production of speech looks at the interaction of different vocal organs, for example the lips, tongue and teeth, to produce particular sounds.
                    </gloss>
                    <note>...</note>
                </item>
                <!--altri termini...-->
            </list>

